<?xml version="1.0" encoding="utf-8"?>
<robot name="mvaibot">
  <!-- ========== base_footprint (地面投影点, 无可视模型) ========== -->
  <link name="base_footprint"/>
  <!-- ========== base_link (底盘主体) ========== -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <geometry>
        <box size="0.8 0.6 0.3"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <geometry>
        <box size="0.8 0.6 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <mass value="20.0"/>
      <inertia ixx="0.7496999999999999" ixy="0" ixz="0" iyy="1.21618" iyz="0" izz="1.666"/>
    </inertial>
  </link>
  <!-- base_footprint -> base_link 关节 (仅做 Z 轴平移) -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.05"/>
  </joint>
</robot>